---
layout: layouts/base.njk
title: Case Studies
description: Strategic UX case studies from Fox & Frame, focused on context, decisions, and outcomes.
navVariant: demos
footer: false
permalink: demos.html
---
<main id="main">
  <header class="section">
    <div class="container">
      <div class="row align-items-end g-4">
        <div class="col-lg-8">
          <p class="text-uppercase small text-muted mb-2">Portfolio</p>
          <h1 class="display-6 fw-semibold mb-2">Case Studies</h1>
          <p class="text-muted mb-0">Strategy-first case studies showing context, constraints, decisions, and qualitative outcomes.</p>
        </div>
        <div class="col-lg-4 text-lg-end">
          <a class="btn btn-outline-secondary" href="/index.html#work"><i class="bi bi-arrow-left me-2"></i>Back to homepage</a>
        </div>
      </div>
    </div>
  </header>

  <section class="section pt-0">
    <div class="container">
      <div class="row g-3" id="ffDemoGrid">
        {% for project in work.items %}
          <div class="col-lg-6">
            <div class="card card-soft h-100 hover-rise">
              <div class="card-body p-4 p-md-5">
                {% if project.showcase and project.showcase.images and (project.showcase.images | length) > 0 %}
                  <div class="showcase mb-4">
                    <div class="showcase-main">
                      <div id="ffCaseCarousel-{{ project.key }}" class="carousel slide ff-showcase-carousel" data-bs-ride="false">
                        <div class="carousel-inner">
                          {% for img in project.showcase.images %}
                            <div class="carousel-item{% if loop.first %} active{% endif %}">
                              <img src="/{{ img.src }}" class="d-block w-100" alt="{{ img.alt or 'Case study preview' }}" loading="lazy" />
                            </div>
                          {% endfor %}
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#ffCaseCarousel-{{ project.key }}" data-bs-slide="prev" aria-label="Previous">
                          <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#ffCaseCarousel-{{ project.key }}" data-bs-slide="next" aria-label="Next">
                          <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        </button>
                      </div>
                    </div>
                    {% if project.showcase.mobile %}
                      <div class="showcase-mobile d-none d-md-block">
                        <img src="/{{ project.showcase.mobile.src }}" alt="{{ project.showcase.mobile.alt or 'Case study mobile preview' }}" loading="lazy" />
                      </div>
                    {% endif %}
                  </div>
                {% endif %}

                <h2 class="h4 fw-semibold mb-1">{{ project.title }}</h2>
                <p class="text-muted mb-3">{{ project.subtitle }}</p>
                <div class="d-flex flex-wrap gap-2 mb-2">
                  {% for t in project.tags %}
                    <span class="chip">{{ t }}</span>
                  {% endfor %}
                </div>
                <div class="d-flex flex-wrap gap-2 mb-3">
                  {% for t in project.tech %}
                    <span class="chip chip-tech">{{ t }}</span>
                  {% endfor %}
                </div>
                <ul class="list-unstyled mb-4 case-card-bullets">
                  {% for item in project.bullets %}
                    <li class="mb-2"><i class="bi bi-check2 me-2"></i>{{ item }}</li>
                  {% endfor %}
                </ul>
                <div class="result-pill mb-4">
                  <i class="bi bi-graph-up-arrow"></i>
                  <span class="fw-semibold">Outcome</span>
                  <span class="text-muted">{{ project.result }}</span>
                </div>
                <div class="d-flex flex-wrap gap-2">
                  <a class="btn btn-primary" href="/{{ project.url }}"><i class="bi bi-box-arrow-up-right me-2"></i>Read case study</a>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <footer class="py-4 border-top bg-white">
    <div class="container">
      <div class="row g-3 align-items-center">
        <div class="col-md-6">
          <div class="d-flex align-items-center gap-2">
            <span class="brand-mark" aria-hidden="true"></span>
            <span class="fw-semibold">Fox &amp; Frame Studio</span>
          </div>
          <div class="small text-muted mt-1">
            UX strategy and product consultancy, South Yorkshire, UK
          </div>
        </div>
        <div class="col-md-6 text-md-end">
          <div class="small text-muted">
            © <span data-year></span> Fox &amp; Frame Studio
            <span class="mx-2">|</span>
            <a class="link-secondary" href="/privacy.html">Privacy</a>
            <span class="mx-2">|</span>
            <a class="link-secondary" href="/terms.html">Terms</a>
          </div>
        </div>
      </div>
    </div>
  </footer>
</main>
